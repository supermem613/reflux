{
  "name": "reflux",
  "version": "0.1.6",
  "description": "Per-identity GitHub credential router for Windows. Routes git auth requests to the right `gh` account so a single sign-in covers all your repos.",
  "type": "module",
  "bin": {
    "reflux": "./dist/cli.js",
    "git-credential-reflux": "./dist/helper.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node test/run.mjs test/**/*.test.ts",
    "test:unit": "node test/run.mjs test/unit/**/*.test.ts",
    "test:integration": "node test/run.mjs test/integration/**/*.test.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/ test/ && tsc --noEmit && tsc --noEmit -p test/tsconfig.json"
  },
  "keywords": [
    "git",
    "credential-helper",
    "github",
    "gh",
    "windows",
    "emu"
  ],
  "license": "MIT",
  "os": [
    "win32"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.17.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "minimatch": "^10.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2"
  }
}
